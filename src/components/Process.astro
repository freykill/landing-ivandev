---
const steps = [
  {
    number: "01",
    title: "Estrategia",
    description: "Entender requisitos, definir alcance y planificar la arquitectura técnica",
  },
  {
    number: "02",
    title: "Arquitectura",
    description: "Diseñar arquitectura de sistema escalable, esquemas de bases de datos y estructuras API",
  },
  {
    number: "03",
    title: "Desarrollo",
    description: "Construir funcionalidades con código limpio, testing automatizado e integración continua",
  },
  {
    number: "04",
    title: "Deploy",
    description: "Configuración de infraestructura en la nube, pipelines CI/CD y despliegue en producción",
  },
  {
    number: "05",
    title: "Optimización",
    description: "Monitoreo de rendimiento, auditorías de seguridad y mejoras continuas",
  },
];
---

<section class="py-20">

  <div class="max-w-7xl mx-auto px-6 flex flex-col lg:gap-30 gap-10">

    <div class="col-span-2 flex justify-center flex-col items-start gap-3">
      <p class="text-sm font-mono tracking-widest text-white/30">05 — PROCESO</p>
      <h4 class="text-4xl lg:text-5xl font-bold tracking-tight">
        Mi <span class="text-white/40">proceso</span>
      </h4>
      <p class="text-lg text-gray-400/90">
        Así llevo una idea desde el papel hasta producción.
      </p>
    </div>


    <!-- Steps -->
    <div class="grid relative grid-cols-1 lg:grid-cols-5 gap-4">

      <div class="absolute z-0 lg:w-full lg:h-px lg:-top-10 w-px left-4.75 bg-linear-to-b h-full lg:bg-linear-to-r lg:from-transparent from-white/20 lg:via-white/20 to-transparent"></div>

      {steps.map((step) => (

      <div class="relative group">

        <div>
          <div class="absolute lg:-top-15 lg:right-25 font-mono z-99 group-hover:border-white/30 transition-colors duration-200 text-white/60 group-hover:text-white bg-[#161616] border-white/10 w-10 h-10 border rounded-full flex items-center justify-center font-bold">
            {step.number}
          </div>
        </div>

        <div class="flex flex-col gap-4 p-5 h-60 border ml-15 lg:m-auto group-hover:border-white/15 rounded-xl bg-[#161616] border-white/6 transition-colors duration-200">

          <!-- Text -->
          <div class="flex flex-col gap-2">
            <h5 class="font-bold text-lg text-white">{step.title}</h5>
            <p class="text-white/35 leading-relaxed">{step.description}</p>
          </div>

        </div>

      </div>

      ))}
    </div>

  </div>
</section>
