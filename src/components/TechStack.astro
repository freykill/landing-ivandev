---
import { ArrowRight, Mail, Code, Shield, Database, Zap } from "@lucide/astro";
---

<section class="py-20">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-2 items-center justify-center gap-10">
    
    <div class="col-span-2 flex justify-center flex-col items-center gap-3">
      <h4 class="text-4xl font-bold">Tech Stack</h4>
      <p class="text-lg text-gray-400/90">
    Tecnología moderna para problemas modernos.
      </p>
    </div>


    <div class="col-span-2 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">

      <div class="bg-red-500/10 border-red-500/40 hover:border-red-500/70  flex flex-col gap-2 p-5 border rounded-xl shadow hover:scale-105 transition-all duration-300 ">
        <h4 class="font-bold text-red-400">Angular</h4>
        <span class="text-sm text-gray-400">Enterprise web applications</span>
      </div>

      <div class="bg-black/20 border-white/10 hover:border-white/30 flex flex-col gap-2 p-5 border rounded-xl shadow hover:scale-105 transition-all duration-300 ">
        <h4 class="font-bold text-white">Next.js</h4>
        <span class="text-sm text-gray-400">SSR & full-stack React apps</span>
      </div>

      <div class="bg-sky-500/10 border-sky-500/40 hover:border-sky-500/70  flex flex-col gap-2 p-5 border rounded-xl shadow hover:scale-105 transition-all duration-300 ">
        <h4 class="font-bold text-sky-400">Tailwind CSS</h4>
        <span class="text-sm text-gray-400">Utility-first styling</span>
      </div>

      <div class="bg-blue-500/10 border-blue-500/40 hover:border-blue-500/70  flex flex-col gap-2 p-5 border rounded-xl shadow hover:scale-105 transition-all duration-300 ">
        <h4 class="font-bold text-blue-400">TypeScript</h4>
        <span class="text-sm text-gray-400">Tipado estático y mayor robustez</span>
      </div>

      <div class="bg-indigo-500/10 border-indigo-500/40 hover:border-indigo-500/70  flex flex-col gap-2 p-5 border rounded-xl shadow hover:scale-105 transition-all duration-300 ">
        <h4 class="font-bold text-indigo-400">PrimeNG</h4>
        <span class="text-sm text-gray-400">UI components para Angular</span>
      </div>

      <div class="bg-purple-500/10 border-purple-500/40 hover:border-purple-500/70  flex flex-col gap-2 p-5 border rounded-xl shadow hover:scale-105 transition-all duration-300 ">
        <h4 class="font-bold text-purple-400">.NET</h4>
        <span class="text-sm text-gray-400">APIs y servicios backend</span>
      </div>

      <div class="bg-orange-500/10 border-orange-500/40 hover:border-orange-500/70  flex flex-col gap-2 p-5 border rounded-xl shadow hover:scale-105 transition-all duration-300 ">
        <h4 class="font-bold text-orange-400">AWS</h4>
        <span class="text-sm text-gray-400">Cloud, despliegue y servicios</span>
      </div>

      <div class="bg-cyan-500/10 border-cyan-500/40 hover:border-cyan-500/70  flex flex-col gap-2 p-5 border rounded-xl shadow hover:scale-105 transition-all duration-300 ">
        <h4 class="font-bold text-cyan-400">Docker</h4>
        <span class="text-sm text-gray-400">Entornos reproducibles</span>
      </div>

      <!-- <div class="bg-yellow-500/10 border-yellow-500/40 hover:border-yellow-500/70 transition-colors flex flex-col gap-2 p-5 border rounded-xl shadow">
        <h4 class="font-bold text-yellow-400">Keycloak</h4>
        <span class="text-sm text-gray-400">Autenticación y gestión de identidad</span>
      </div> -->

    </div>


  </div>

  <!-- IMG -->
</section>
