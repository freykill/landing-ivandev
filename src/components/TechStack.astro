---

<section class="py-20">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-2 items-center justify-center gap-10">

    <div class="col-span-2 flex justify-center flex-col items-start gap-3">
      <p class="text-sm font-mono tracking-widest text-white/30">02 — STACK</p>
      <h4 class="text-4xl lg:text-5xl font-bold tracking-tight">
        Tech <span class="text-white/40">Stack</span>
      </h4>
      <p class="text-lg text-gray-400/90">
        Las herramientas con las que trabajo día a día.
      </p>
    </div>

    <div class="col-span-2 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      {tools.map((tool) => (
        <div class="col-span-2 lg:col-span-1 group border border-white/6 hover:border-white/15 flex flex-col gap-3 p-5 rounded-xl bg-[#161616] transition-colors duration-200">
          {tool.icon === "lucide" ? (
            <Component class="w-7 h-7 text-white/25 group-hover:text-white/60 transition-colors duration-200" />
          ) : (
            <svg
              role="img"
              viewBox="0 0 24 24"
              aria-label={tool.name}
              class="w-7 h-7 fill-current text-white/25 group-hover:text-white/60 transition-colors duration-200"
            >
              <title>{tool.name}</title>
              <path d={tool.path} />
            </svg>
          )}
          <div class="flex flex-col gap-1">
            <h4 class="font-semibold text-lg text-white">{tool.name}</h4>
            <span class="text-gray-400 text-sm">{tool.description}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
