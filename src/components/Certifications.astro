    year: "2024",
    url: "",
    category: "TÍTULO",
  },

  // ── Idiomas ──
  {
    title: "Inglés — Nivel 6",
    issuer: "Universidad Técnica de Machala · Centro de Educación Continua",
    year: "2026",
    url: "",
    category: "IDIOMAS",
  },

  // ── Cisco Networking Academy ──
  {
    title: "Fundamentos de Python 1",
    issuer: "Cisco Networking Academy",
    year: "",
    url: "",
    category: "CISCO",
  },
  {
    title: "NDG Linux Unhatched",
    issuer: "Cisco Networking Academy",
    year: "",
    url: "",
    category: "CISCO",
  },
  {
    title: "Introduction to Cybersecurity",
    issuer: "Cisco Networking Academy",
    year: "",
    url: "",
    category: "CISCO",
  },

  // ── Udemy ──
  {
    title: "Programación Backend en C# .NET",
    issuer: "Udemy",
    year: "2026",
    url: "https://ude.my/UC-c3b86f17a-adb9-48f8-b001-148ac3c0dcde",
    category: "UDEMY",
  },
  {
    title: "Principios SOLID y Clean Code",
    issuer: "Udemy",
    year: "2026",
    url: "https://ude.my/UC-e0709d72-8972-4658-ae64-e63d04539538",
    category: "UDEMY",
  },
  {
    title: "API REST Full completa con PHP Nativo",
    issuer: "Udemy",
    year: "",
    url: "",
    category: "UDEMY",
  },
  {
    title: "SQL de cero: Tu guía práctica con PostgreSQL",
    issuer: "Udemy",
    year: "2026",
    url: "https://ude.my/UC-e1894637-baf5-4300-9bb4-606d97d4f470",
    category: "UDEMY",
  },
  {
    title: "GIT+GitHub: Todo un sistema de control de versiones de cero",
    issuer: "Udemy",
    year: "2026",
    url: "https://ude.my/UC-8d26f63d-ca50-4c1c-ad7f-99cc6ab24532",
    category: "UDEMY",
  },

  // ── Otros cursos ──
  {
    title: "Claude Code 101",
    issuer: "Anthropic",
    year: "2026",
    url: "https://verify.skilljar.com/c/8vcc5r8zneqy",
    category: "CURSOS",
  },
  {
    title: ".NET Backend: .NET Core, SQL Server y seguridad JWT",
    issuer: "DevTalles",
    year: "2026",
    url: "https://cursos.devtalles.com/certificates/qmetmiwipb",
    category: "CURSOS",
  },
  {
    title: "Python Dominio Medio – Avanzado",
    issuer: "Universidad Estatal de Milagro",
    year: "",
    url: "",
    category: "CURSOS",
  },
  {
    title: "Bases de Datos SQL desde Cero",
    issuer: "EDteam",
    year: "",
    url: "",
    category: "CURSOS",
  },
  {
    title: "Business Partner Integrity",
    issuer: "IBM",
