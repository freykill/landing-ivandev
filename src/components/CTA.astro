---
import { ArrowRight, Mail, Github, Linkedin } from "@lucide/astro";
---

<section class="py-28 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,#2d1b6b_0%,transparent_60%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,#1a0f4a_0%,transparent_50%)]"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-6 flex flex-col items-center text-center gap-6">

    <!-- Title -->
    <h2 class="text-4xl sm:text-5xl font-bold leading-tight">
      Need a Secure and{" "}
      <span class="bg-linear-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent">
        Scalable System?
      </span>
    </h2>

    <!-- Subtitle -->
    <p class="text-gray-400 text-lg max-w-xl">
      Let's discuss how I can help architect and build your next production-ready application
    </p>

    <!-- Buttons -->
    <div class="flex gap-4 flex-wrap justify-center mt-2">
      <button class="flex group gap-2 cursor-pointer hover:brightness-120 items-center bg-linear-to-r from-purple-700 to-blue-500 px-6 py-3 rounded-xl font-semibold">
        <Mail class="w-4 h-4" />
        Get In Touch
        <ArrowRight class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" />
      </button>

      <button class="flex cursor-pointer hover:brightness-120 items-center bg-transparent ring ring-white/20 hover:ring-white/40 px-6 py-3 rounded-xl font-semibold transition-all duration-300">
        View All Projects
      </button>
    </div>

    <!-- Social Icons -->
    <div class="flex gap-3 mt-4">
      <a href="#" class="w-10 h-10 border border-white/15 rounded-xl flex items-center justify-center hover:border-white/30 hover:bg-white/5 transition-all duration-300">
        <Github class="w-4 h-4 text-gray-400" />
      </a>
      <a href="#" class="w-10 h-10 border border-white/15 rounded-xl flex items-center justify-center hover:border-white/30 hover:bg-white/5 transition-all duration-300">
        <Linkedin class="w-4 h-4 text-gray-400" />
      </a>
      <a href="#" class="w-10 h-10 border border-white/15 rounded-xl flex items-center justify-center hover:border-white/30 hover:bg-white/5 transition-all duration-300">
        <Mail class="w-4 h-4 text-gray-400" />
      </a>
    </div>

  </div>
</section>
