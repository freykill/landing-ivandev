---
import { ExternalLink, Github, Lock } from "@lucide/astro";

const projects = [
  {
    title: "E-commerce egeek",
    description:
      "Tienda online donde el cliente busca productos, arma su carrito y confirma el pedido por WhatsApp, sin necesidad de crear una cuenta. Una misma plataforma se adapta a varias tiendas: cada una con su propio nombre, logo y colores.",
    stack: "Angular / NestJS / PostgreSQL / Cloudinary / Resend / VPS",
    demo: "https://ecommerce-egeek.vercel.app/",
    github: "https://github.com/freykill/ecommerce-egeek",
  },
  {
    title: "Finance Application Platform",
    description:
      "App para gestionar finanzas personales — ingresos, gastos y balance en tiempo real. Auth con JWT + refresh token y deploy automatizado con GitHub Actions y Docker en servidor propio.",
    stack: "Angular / Node / Postgres / Docker / TypeScript",
    demo: "https://fiz-ng.vercel.app/auth/login",
    github: "https://github.com/freykill/fiz-ng",
  },
  {
    title: "Motor de reglas",
    description:
      "Motor de reglas de negocio configurable: condiciones, prioridades y acciones que se definen sin tocar código. Pensado para que el área operativa ajuste la lógica sin esperar un deploy.",
    stack: ".NET / Angular / Azure / SQL Server",
    confidential: true,
  },
  {
    title: "Facturación electrónica",
    description:
      "Sistema de facturación electrónica: emisión y autorización de comprobantes con procesamiento asíncrono mediante lambdas, diseñado para soportar picos de carga sin perder documentos.",
    stack: "Angular / Node / AWS Lambda / PostgreSQL",
    confidential: true,
  },
  {
    title: "Plataforma de seguridad",
    description:
      "Base de seguridad centralizada: autenticación, manejo de roles y auditoría como servicio compartido para varias aplicaciones internas, en lugar de repetir el login en cada una.",
    stack: "Next.js / Node / AWS / PostgreSQL",
    confidential: true,
  },
];
---

<section class="py-20" id="projects">
  <div class="max-w-7xl mx-auto px-6 flex flex-col gap-10">
    <div class="flex flex-col items-start gap-3">
      <p class="text-sm font-mono tracking-widest text-white/30">03 — PROYECTOS</p>
      <h2 class="text-4xl lg:text-5xl font-bold tracking-tight">
        Lo que he <span class="text-white/40">construido</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      {projects.map((project, i) => (
        <article class="flex flex-col gap-5 p-8 border border-white/6 hover:border-white/15 rounded-xl bg-[#161616] transition-colors duration-200">
          <div class="flex items-start justify-between gap-4">
            <div class="flex flex-col gap-2">
              <p class="text-sm font-mono tracking-widest text-white/30">
                {String(i + 1).padStart(2, "0")}
              </p>
              <h3 class="text-2xl font-semibold tracking-tight">{project.title}</h3>
            </div>

            {project.confidential && (
              <div class="flex shrink-0 items-center gap-2 font-mono text-[11px] tracking-widest border border-amber-400/20 bg-amber-400/5 text-amber-300/80 rounded-full px-3 py-1.5 mt-1">
                <Lock class="w-3.5 h-3.5" />
                CONFIDENCIAL
              </div>
            )}
          </div>

          <p class="text-white/50 leading-relaxed">{project.description}</p>

          <p class="font-mono text-sm tracking-widest text-white/25 uppercase mt-auto">
            {project.stack}
          </p>

          {project.confidential ? (
            <p class="font-mono text-xs text-white/25 border-t border-white/6 pt-4">
              Proyecto bajo acuerdo de confidencialidad
            </p>
          ) : (
            <div class="flex flex-wrap gap-3 border-t border-white/6 pt-4">
              <a
                href={project.demo}
                target="_blank"
                rel="noopener noreferrer"
                class="w-full lg:w-auto justify-center flex gap-2 cursor-pointer items-center bg-[#7c5cfc] hover:bg-[#9f82ff] transition-colors duration-200 px-5 py-2.5 rounded-full font-semibold text-sm"
              >
                <ExternalLink class="w-4" />
                Ver proyecto
              </a>
              <a
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                class="w-full lg:w-auto justify-center flex gap-2 cursor-pointer items-center bg-[#1d1d1d] hover:bg-[#7c5cfc] transition-colors duration-200 px-5 py-2.5 rounded-full font-semibold text-sm"
              >
                <Github class="w-4" />
                GitHub
              </a>
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
