---
import { ArrowRight, Mail, Code, Shield, Database, Zap } from "@lucide/astro";
---

<section class="py-20" id="projects">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-2 items-center justify-center gap-10">

    <div class="col-span-2 flex justify-center flex-col items-center gap-3">
      <h4 class="text-4xl font-bold text-center">Finance Application Platform</h4>
      <p class="text-lg text-gray-400/90">
        Tecnología moderna para problemas modernos.
      </p>
    </div>

    <div class="col-span-2 lg:col-span-1 relative h-150 flex justify-center items-center">

      <img
        src="/fiz.png"
        class="object-cover h-full rounded-2xl shadow"
        alt="Finance Application Platform"
      />

      <div class="absolute top-5 right-5">
        <div class="bg-green-500/20 px-2 py-1 border border-green-300  rounded-lg shadow">
          <h4 class="text-green-400 text-xs">Produccion Listo</h4>
        </div>
      </div>



    </div>

    <div class="col-span-2 lg:col-span-1">

      <div class="border border-gray-500/40 rounded-2xl flex gap-3 p-5 bg-[#151F33]/40 ">
        <div class="flex justify-center items-center">
          <div class="bg-purple-500/40 p-3 1 w-12 rounded-xl shadow">
            <Code class="text-purple-500" />
          </div>
        </div>

        <div class="">
          <h4 class="font-bold">Secure Authentication</h4>
          <span class="text-gray-400/40"
            >Implementación de sistemas de autenticación robustos
          </span>
        </div>
      </div>

      <!-- Nuevo bloque de feature card -->
      <div class="border border-gray-500/40 rounded-2xl flex gap-3 p-5 bg-[#151F33]/40 mt-4">
        <div class="flex justify-center items-center">
          <div class="bg-purple-500/40 p-3 w-12 rounded-xl shadow">
            <Shield class="text-purple-500" />
          </div>
        </div>
        <div>
          <h4 class="font-bold">Role-Based Access</h4>
          <span class="text-gray-400/40">
            Permisos granulares para diferentes tipos de usuario
          </span>
        </div>
      </div>

      <!-- Clean UI/UX -->
      <div class="border border-gray-500/40 rounded-2xl flex gap-3 p-5 bg-[#151F33]/40 mt-4">
        <div class="flex justify-center items-center">
          <div class="bg-purple-500/40 p-3 w-12 rounded-xl shadow">
            <Mail class="text-purple-500" />
          </div>
        </div>
        <div>
          <h4 class="font-bold">Clean UI/UX</h4>
          <span class="text-gray-400/40">
            Interfaz intuitiva construida con frameworks modernos
          </span>
        </div>
      </div>

      <!-- Scalable Architecture -->
      <div class="border border-gray-500/40 rounded-2xl flex gap-3 p-5 bg-[#151F33]/40 mt-4">
        <div class="flex justify-center items-center">
          <div class="bg-purple-500/40 p-3 w-12 rounded-xl shadow">
            <Database class="text-purple-500" />
          </div>
        </div>
        <div>
          <h4 class="font-bold">Scalable Architecture</h4>
          <span class="text-gray-400/40">
            Infraestructura AWS capaz de manejar miles de transacciones
          </span>
        </div>
      </div>


      <!-- tecnolgias -->
      <div class="grid grid-cols-6 gap-2 mt-6">
        <div class="border rounded-full border-gray-800 px-2 py-1 col-span-1 flex justify-center items-center ">
          <p class="text-xs text-white">Angular</p>
        </div>

        <div class="border rounded-full border-gray-800 px-2 py-1 col-span-1 flex justify-center items-center ">
          <p class="text-xs text-white">Posgres</p>
        </div>

        <div class="border rounded-full border-gray-800 px-2 py-1 col-span-1 flex justify-center items-center ">
          <p class="text-xs text-white">Docker</p>
        </div>

        <div class="border rounded-full border-gray-800 px-2 py-1 col-span-1 flex justify-center items-center ">
          <p class="text-xs text-white">TypeScript</p>
        </div>

        <div class="border rounded-full border-gray-800 px-2 py-1 col-span-1 flex justify-center items-center ">
          <p class="text-xs text-white">Sequelize</p>
        </div>

      </div>

      
    </div>
  </div>

  <!-- IMG -->
</section>
