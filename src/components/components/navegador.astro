<!-- BrowserMockup.astro -->
---
interface Props {
  src: string;
  alt?: string;
  url?: string;
}
const { src, alt = "Project screenshot", url = "app.fiz.com" } = Astro.props;
---

<div class="rounded-2xl border border-white/6 overflow-hidden shadow-[0_32px_80px_rgba(0,0,0,0.5)] bg-[#0e1020]/80 w-full backdrop-blur-xl">
  
  <!-- Browser header -->
  <div class="flex items-center gap-2 px-4 py-3 bg-white/3 border-b border-white/6">
    <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></span>
    <span class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></span>
    <span class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></span>

    <!-- URL bar -->
    <div class="flex-1 mx-3 bg-white/4 border border-white/6 rounded-md px-3 py-1 flex items-center gap-2">
      <svg class="w-3 h-3 text-white/20 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      <span class="font-mono text-[11px] text-white/25 truncate">{url}</span>
    </div>

    <!-- Status badge -->
    <div class="flex items-center gap-1.5 bg-green-500/10 border border-green-500/20 rounded-full px-2.5 py-1">
      <span class="w-1.5 h-1.5 rounded-full bg-green-400 shadow-[0_0_6px_#4ade80] animate-pulse"></span>
      <span class="font-mono text-[10px] text-green-400">Online</span>
    </div>
  </div>

  <!-- Screenshot -->
  <div class="w-full  overflow-hidden">
    <img src={src} alt={alt} class="w-full h-full object-cover object-top" />
  </div>

</div>