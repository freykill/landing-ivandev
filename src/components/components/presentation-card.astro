---
---

<div class="w-full max-w-md" id="hero-card-wrap">
  <div
    id="hero-card"
    class="relative rounded-2xl border border-white/6 bg-[#161616] overflow-hidden shadow-[0_32px_80px_rgba(0,0,0,0.5)] will-change-transform"
  >
    <!-- Cover -->
    <div class="h-36 overflow-hidden">
      <img
        src="/hero.jpg"
        alt="Setup de trabajo de Ivan Diaz"
        class="w-full h-full object-cover opacity-80"
      />
    </div>

    <!-- Avatar -->
    <div class="px-6">
      <div
        data-card-item
        class="-mt-9 w-18 h-18 rounded-full bg-[#7c5cfc] border-4 border-[#161616] flex items-center justify-center font-bold text-xl tracking-tight"
      >
        ID
      </div>
    </div>

    <!-- Body -->
    <div class="px-6 pt-4 pb-6 flex flex-col gap-4">
      <div data-card-item class="flex flex-col gap-1">
        <h3 class="text-2xl font-bold tracking-tight">Ivan Diaz</h3>
        <p class="font-mono text-xs tracking-widest text-[#7c5cfc] uppercase">
          Full-Stack Developer
        </p>
      </div>

      <div data-card-item class="flex items-center gap-2 text-xs font-mono text-green-400">
        <span class="relative flex w-2 h-2">
          <span class="absolute inline-flex w-full h-full rounded-full bg-green-500 animate-ping opacity-75"></span>
          <span class="relative inline-flex w-2 h-2 rounded-full bg-green-500"></span>
        </span>
        Disponible para proyectos
      </div>

      <div data-card-item class="h-px bg-white/6"></div>

      <!-- Stats -->
      <div data-card-item class="grid grid-cols-3 gap-4">
        <div class="flex flex-col gap-1">
          <span class="font-extrabold text-2xl tracking-tight text-white/90">
            3<span class="text-[#7c5cfc]">+</span>
          </span>
          <span class="text-xs text-white/30">Años de experiencia</span>
        </div>
        <div class="flex flex-col gap-1">
          <span class="font-extrabold text-2xl tracking-tight text-white/90">
            10<span class="text-[#7c5cfc]">+</span>
          </span>
          <span class="text-xs text-white/30">Proyectos completados</span>
        </div>
        <div class="flex flex-col gap-1">
          <span class="font-extrabold text-2xl tracking-tight text-white/90">
            8<span class="text-[#7c5cfc]">+</span>
          </span>
          <span class="text-xs text-white/30">Tech stack</span>
        </div>
      </div>

      <div data-card-item class="font-mono text-[11px] tracking-widest text-white/25 uppercase">
        fabriciodiazpay@gmail.com
      </div>
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  const wrap = document.getElementById("hero-card-wrap");
  const card = document.getElementById("hero-card");

  if (wrap && card) {
    // Entrada: la card sube y sus elementos aparecen en cascada
    gsap.from(card, { y: 40, opacity: 0, duration: 1, ease: "power3.out" });
    gsap.from(card.querySelectorAll("[data-card-item]"), {
      y: 16,
      opacity: 0,
      duration: 0.7,
      stagger: 0.08,
      delay: 0.25,
      ease: "power3.out",
    });

    // Tilt 3D sutil siguiendo el mouse
    gsap.set(card, { transformPerspective: 900 });
    const rotateX = gsap.quickTo(card, "rotationX", { duration: 0.5, ease: "power3.out" });
    const rotateY = gsap.quickTo(card, "rotationY", { duration: 0.5, ease: "power3.out" });

    wrap.addEventListener("mousemove", (e) => {
      const rect = wrap.getBoundingClientRect();
      const px = (e.clientX - rect.left) / rect.width - 0.5;
      const py = (e.clientY - rect.top) / rect.height - 0.5;
      rotateY(px * 10);
      rotateX(-py * 8);
    });

    wrap.addEventListener("mouseleave", () => {
      rotateX(0);
      rotateY(0);
    });
  }
</script>
