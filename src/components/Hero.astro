---

<section class="lg:h-screen h-auto relative overflow-hidden py-20 flex flex-col items-center justify-center">

  <!-- Lanyard 3D: solo desktop (en móvil se oculta y no se monta el canvas) -->
<div class="hidden lg:block lg:absolute lg:inset-0 lg:z-10">
  <!-- position: [x, y, z] de la cámara — x más negativo = gafete más a la DERECHA,
       y más negativo = gafete más arriba, z más chico = gafete más grande -->
  <Lanyard client:only="react" position={[-2.5, -0.5, 18]} />
</div>

  <div class="max-w-7xl w-full mx-auto px-6 grid grid-cols-2 items-center justify-center gap-15 relative z-20 pointer-events-none">
    
    
    <div id="hero-copy" class="col-span-2 lg:col-span-1 flex flex-col justify-center gap-8 pointer-events-auto">
      
        <!-- <div class="border-green-400/30 bg-green-500/10 mb-3 py-2 w-fit border px-3 rounded-full flex items-center gap-2 text-xs font-mono">
          <div class="relative flex items-center justify-center w-2 h-2">
            <div class="absolute bg-green-500 rounded-full w-2 h-2 animate-ping opacity-75"></div>
            <div class="bg-green-600 rounded-full w-2 h-2"></div>
        </div>
          <p class="text-green-400">Disponible para proyectos</p>
        </div>
 -->
        <!-- title principal -->
        
        <div class="flex flex-col gap-4 text-left">
          <p class="text-[#7c5cfc] text-sm font-mono tracking-widest uppercase">Full-Stack Developer</p>
          <h1 class="text-6xl lg:text-7xl font-bold tracking-tight leading-[0.95] uppercase">
            Ivan<br />Diaz
          </h1>
        </div>

        <!-- description -->
        <p class="text-lg text-white/35 text-left">
          Desarrollo soluciones completas con
          <span class="text-white font-semibold">Angular, .NET, Node y AWS</span> —
          desde la interfaz hasta el servidor. Me enfoco en escribir código limpio,
          escalable y listo para producción, entendiendo el problema antes de
          escribir la primera línea.
        </p>

        <!-- botonera -->
        <div class="flex flex-wrap gap-3">
          <button onclick="document.getElementById('projects').scrollIntoView({ behavior: 'smooth' })"
            class=" w-full lg:w-60 justify-center  flex group gap-1 cursor-pointer items-center bg-[#7c5cfc] hover:bg-[#9f82ff] transition-colors duration-200  px-6 py-3 rounded-full font-semibold"
          >
              Ver proyectos
            <ArrowRight
              class="w-5 transition-transform duration-300 group-hover:translate-x-1"
            />
          </button>

          <button onclick="document.getElementById('cta').scrollIntoView({ behavior: 'smooth' })"
            class="w-full lg:w-60 justify-center flex group gap-2 cursor-pointer items-center bg-[#1d1d1d] hover:bg-[#7c5cfc] transition-colors duration-200 px-6 py-3 rounded-full font-semibold"
          >
            <Mail class="w-5" />
            Contactame
          </button>
        </div>

        <!-- stack: logos en gris (Simple Icons, monocromáticos) separados por slash -->
        <div class="flex items-center gap-4 text-white/25">
          {stack.map((tech, i) => (
            <>
              {i > 0 && <span class="font-mono select-none">/</span>}
              <svg
                role="img"
                viewBox="0 0 24 24"
                aria-label={tech.name}
                class="w-6 h-6 fill-current hover:text-white/60 transition-colors duration-200"
              >
                <title>{tech.name}</title>
                <path d={tech.path} />
              </svg>
            </>
          ))}
        </div>

        <!-- stats -->
        <!-- <div class="flex gap-10 mt-10">
          <div class="flex flex-col">
            <h4 class="p-0 font-bold text-2xl">5+</h4>
            <span class="text-xs p-0 text-gray-400">Years Experience</span>
          </div>

          <div class="flex flex-col">
            <h4 class="p-0 font-bold text-2xl">50+</h4>
            <span class="text-xs p-0 text-gray-400">Projects Completed</span>
          </div>

          <div class="flex flex-col">
            <h4 class="p-0 font-bold text-2xl">99.9%</h4>
            <span class="text-xs p-0 text-gray-400">Client Satisfaction</span>
          </div>
        </div> -->
    </div>

  </div>

  <!-- indicador de scroll: solo desktop, centrado abajo, baja a la siguiente sección -->
  <button
    onclick="this.closest('section').nextElementSibling?.scrollIntoView({ behavior: 'smooth' })"
    aria-label="Desliza para ver más"
    class="hidden lg:flex absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex-col items-center gap-3 cursor-pointer text-white/30 hover:text-[#9f82ff] transition-colors duration-200 group"
  >
    <span class="w-6 h-10 rounded-full border-2 border-current flex justify-center pt-2">
      <span class="w-1 h-2 rounded-full bg-current animate-scroll-wheel"></span>
    </span>
    <span class="font-mono text-[10px] tracking-[0.3em] uppercase">Scroll</span>
  </button>
</section>

<style>
  @keyframes scroll-wheel {
    0% { transform: translateY(0); opacity: 1; }
    70% { transform: translateY(10px); opacity: 0; }
    100% { transform: translateY(0); opacity: 0; }
  }
  .animate-scroll-wheel {
    animation: scroll-wheel 1.6s ease-in-out infinite;
  }
</style>
