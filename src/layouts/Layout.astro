---
interface Props {
  title: string;
}



const { title } = Astro.props;
import '../pages/styles/global.css';
import Analytics from '@vercel/analytics/astro'
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="512x512" href="/favicon-512.png" />

    <!-- Primary Meta Tags -->
    <title>Full-Stack Developer | Angular, .NET, Node, AWS</title>
    <meta name="title" content="Full-Stack Developer | Angular, .NET, Node, AWS" />
    <meta name="description" content="Desarrollo soluciones completas desde la interfaz hasta el servidor. Código limpio, escalable y listo para producción." />
    <meta name="author" content="Ivan Dev" />
    <meta name="robots" content="index, follow" />
    <meta name="keywords" content="full-stack developer, angular, .net, nodejs, aws, typescript, docker, web development, portfolio" />
    <link rel="canonical" href="https://landing-ivandev.vercel.app/" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://landing-ivandev.vercel.app/" />
    <meta property="og:title" content="Full-Stack Developer | Angular, .NET, Node, AWS" />
    <meta property="og:description" content="Desarrollo soluciones completas desde la interfaz hasta el servidor. Código limpio, escalable y listo para producción." />
    <meta property="og:image" content="https://landing-ivandev.vercel.app/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://landing-ivandev.vercel.app/" />
    <meta property="twitter:title" content="Full-Stack Developer | Angular, .NET, Node, AWS" />
    <meta property="twitter:description" content="Desarrollo soluciones completas desde la interfaz hasta el servidor. Código limpio, escalable y listo para producción." />
    <meta property="twitter:image" content="https://landing-ivandev.vercel.app/og-image.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#080B14] text-white font-sans antialiased ">
    <slot />
    <footer class="border-t border-white/10 py-5">
      <div class="max-w-7xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-gray-500">
        <p>© 2026 Full-Stack Developer. Built with precision.</p>
        <div class="flex gap-6">
          <!-- <a href="#" class="hover:text-gray-300 transition-colors duration-200">Privacy Policy</a>
          <a href="#" class="hover:text-gray-300 transition-colors duration-200">Terms of Service</a> -->
        </div>
      </div>
    </footer>
    <Analytics />
  </body>
</html>

<style is:global>
  body {
    font-family: 'Inter', sans-serif;
  }
</style>