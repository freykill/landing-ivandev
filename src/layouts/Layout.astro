---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/src/pages/styles/global.css" />
  </head>
  <body class="bg-[#080B14] text-white font-sans antialiased ">
    <slot />
    <footer class="border-t border-white/10 py-5">
      <div class="max-w-7xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-gray-500">
        <p>© 2026 Full-Stack Developer. Built with precision.</p>
        <div class="flex gap-6">
          <!-- <a href="#" class="hover:text-gray-300 transition-colors duration-200">Privacy Policy</a>
          <a href="#" class="hover:text-gray-300 transition-colors duration-200">Terms of Service</a> -->
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  body {
    font-family: 'Inter', sans-serif;
  }
</style>